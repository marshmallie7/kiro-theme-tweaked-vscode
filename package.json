{
  "name": "kiro-theme-scala",
  "displayName": "Kiro Theme (Scala Patch)",
  "description": "A fork of Kiro Theme for VSCode by Mohd Zaid, patched to improve Scala highlighting",
  "version": "1.1.0",
  "publisher": "elliepreston",
  "engines": {
    "vscode": "^1.18.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "light",
    "color-theme",
    "kiro",
    "modern",
    "vibrant",
    "scala"
  ],
  "license": "MIT",
  "homepage": "https://github.com/marshmallie7/kiro-theme-scala-vscode/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/marshmallie7/kiro-theme-scala-vscode.git"
  },
  "contributes": {
    "themes": [
      {
        "label": "Kiro Dark (Scala Patch)",
        "uiTheme": "vs-dark",
        "path": "./themes/kiro-dark-scala-patch.json"
      },
      {
        "label": "Kiro Light (Scala Patch)",
        "uiTheme": "vs",
        "path": "./themes/kiro-light-scala-patch.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "echo 'No compilation needed for theme'",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
